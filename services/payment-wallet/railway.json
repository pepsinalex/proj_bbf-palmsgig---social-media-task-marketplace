{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "poetry install --only=main"
  },
  "deploy": {
    "startCommand": "poetry run uvicorn src.payment_wallet.main:app --host 0.0.0.0 --port ${PORT:-8004}",
    "healthcheckPath": "/health"
  }
}