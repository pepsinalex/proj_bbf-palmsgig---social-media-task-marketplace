{
  "build": {
    "builder": "nixpacks",
    "buildCommand": "pip install poetry && poetry install --only=main"
  },
  "deploy": {
    "startCommand": "poetry run uvicorn src.social_media_integration.main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}