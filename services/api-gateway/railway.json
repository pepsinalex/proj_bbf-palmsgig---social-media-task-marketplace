{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "poetry run gunicorn -k uvicorn.workers.UvicornWorker -w 4 -b 0.0.0.0:$PORT src.api_gateway.main:app",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}