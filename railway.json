{
  "build": {
  "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "poetry run uvicorn src.user_management.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}